# Copy to backend/.env. All variables are prefixed BI_ (see config/settings.py).

# ── HTTP / app ──────────────────────────────────────────────────────────────
BI_ROOT_PATH=
BI_CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
BI_LOG_LEVEL=INFO
BI_JSON_LOGS=true

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Dev: HS256 shared secret. Prod: leave secret empty and set the RS256 PEM path.
BI_JWT_SECRET=change-me-in-prod-use-a-32-byte-secret
BI_JWT_PUBLIC_KEY_PATH=
BI_JWT_AUDIENCE=enterprise-bi
BI_JWT_ISSUERS=["enterprise-bi-dev"]
# DEV ONLY: expose POST /api/v1/dev/login so the SPA can mint a token per role.
BI_ALLOW_DEV_LOGIN=false

# ── Database (analytical reads) ──────────────────────────────────────────────
BI_DATABASE_URL=mysql+pymysql://bi:bi@localhost:3306/ENTERPRISE_BI
BI_MAX_ROWS=10000

# ── LLM (leave both empty to run the deterministic OfflineCompleter) ──────────
BI_OPENAI_API_KEY=
BI_GEMINI_API_KEY=
BI_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ── Guardrails / exports / memory ────────────────────────────────────────────
BI_GUARDRAIL_MAX_LENGTH=2000
BI_EXPORT_DIR=exports
BI_REDIS_URL=redis://localhost:6379/0
BI_MEMORY_TTL_SECONDS=3600
