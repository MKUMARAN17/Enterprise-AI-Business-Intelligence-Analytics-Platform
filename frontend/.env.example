# Copy to .env.local. All frontend env vars are prefixed VITE_.

# Backend base URL (the FastAPI service).
VITE_API_BASE_URL=http://localhost:8000

# Auth mode. "dev" → the backend's POST /api/v1/dev/login mints a token per role
# (requires BI_ALLOW_DEV_LOGIN=true on the backend).
VITE_AUTH_MODE=dev

# Branding shown in the top bar.
VITE_PRODUCT_NAME=Enterprise BI
